rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /children/{childId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.parents;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.parents;

      allow update: if request.auth != null && (
        request.auth.uid in resource.data.parents
        || (
          request.auth.uid in request.resource.data.parents
          && request.auth.uid not in resource.data.parents
          && request.auth.token.email in resource.data.parentEmails
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.name == resource.data.name
          && request.resource.data.birthDate == resource.data.birthDate
          && request.resource.data.parents.size() == resource.data.parents.size() + 1
          && request.resource.data.parentEmails.size() == resource.data.parentEmails.size()
        )
      );
    }

    match /custodyPatterns/{patternId} {
      allow read, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parents;
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(request.resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(request.resource.data.childId)).data.parents;
    }

    match /custodyOverrides/{overrideId} {
      allow read, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parents;
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(request.resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(request.resource.data.childId)).data.parents;
    }

    match /changeRequests/{requestId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.fromParentId || request.auth.uid == resource.data.toParentId);
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromParentId;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.toParentId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']);
    }

    match /invitations/{invitationId} {
      allow read: if request.auth != null
        && (request.auth.token.email == resource.data.toEmail || request.auth.token.email == resource.data.fromEmail);
      allow create: if request.auth != null
        && request.auth.token.email == request.resource.data.fromEmail;
      allow update: if request.auth != null
        && request.auth.token.email == resource.data.toEmail
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    match /notes/{noteId} {
      allow read, delete: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parents;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.createdBy
        && exists(/databases/$(database)/documents/children/$(request.resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(request.resource.data.childId)).data.parents;
      allow update: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parents
        && request.resource.data.childId == resource.data.childId
        && request.resource.data.createdBy == resource.data.createdBy;
    }

    match /schoolEvents/{eventId} {
      allow read, update: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parents;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.createdBy
        && exists(/databases/$(database)/documents/children/$(request.resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(request.resource.data.childId)).data.parents;
      allow delete: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parents;
    }

    match /packingItems/{itemId} {
      allow read, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parents;
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(request.resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(request.resource.data.childId)).data.parents;
    }

    match /specialPeriods/{periodId} {
      allow read, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parents;
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/children/$(request.resource.data.childId))
        && request.auth.uid in get(/databases/$(database)/documents/children/$(request.resource.data.childId)).data.parents;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function childForId(childId) {
      return get(/databases/$(database)/documents/children/$(childId));
    }

    function isParentForChild(childId) {
      return request.auth != null && exists(/databases/$(database)/documents/children/$(childId)) && request.auth.uid in childForId(childId).data.parents;
    }

    function isCollaboratorForChild(childId) {
      return request.auth != null && exists(/databases/$(database)/documents/children/$(childId)) && childForId(childId).data.collaborators != null && request.auth.uid in childForId(childId).data.collaborators;
    }

    function collaboratorHasFullCalendar(childId) {
      return isCollaboratorForChild(childId)
        && childForId(childId).data.collaboratorCalendarAccess != null
        && childForId(childId).data.collaboratorCalendarAccess[request.auth.uid] == 'all';
    }

    match /children/{childId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.parents ||
        (resource.data.collaborators != null && request.auth.uid in resource.data.collaborators)
      );
      allow create: if request.auth != null && request.auth.uid in request.resource.data.parents;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.parents ||
        (
          resource.data.collaboratorEmails != null &&
          request.auth.token.email in resource.data.collaboratorEmails &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'collaborators',
            'collaboratorEmails',
            'collaboratorNames',
            'collaboratorLabels',
            'collaboratorDocumentAccess',
            'collaboratorCalendarAccess',
            'collaboratorCalendarApprovedBy'
          ])
        ) ||
        (resource.data.parents.size() < 2 && request.auth.uid in request.resource.data.parents && request.resource.data.parents.size() <= 2)
      );
    }
    match /custodyPatterns/{patternId} {
      allow read: if isParentForChild(resource.data.childId) || collaboratorHasFullCalendar(resource.data.childId);
      allow update, delete: if isParentForChild(resource.data.childId);
      allow create: if isParentForChild(request.resource.data.childId);
    }
    match /custodyOverrides/{overrideId} {
      allow read: if isParentForChild(resource.data.childId) || collaboratorHasFullCalendar(resource.data.childId);
      allow update, delete: if isParentForChild(resource.data.childId);
      allow create: if isParentForChild(request.resource.data.childId);
    }
    match /changeRequests/{requestId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.fromParentId || request.auth.uid == resource.data.toParentId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromParentId;
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.toParentId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']))
        ||
        (request.auth.uid == resource.data.fromParentId && resource.data.status == 'pending' && request.resource.data.status == 'cancelled' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']))
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.fromParentId || request.auth.uid == resource.data.toParentId
      ) && resource.data.status == 'cancelled';
    }
    match /collaboratorAssignments/{assignmentId} {
      allow read: if isParentForChild(resource.data.childId) || (request.auth != null && request.auth.uid == resource.data.collaboratorId && isCollaboratorForChild(resource.data.childId));
      allow create: if request.auth != null && request.auth.uid == request.resource.data.createdByParentId && isParentForChild(request.resource.data.childId);
      allow update: if isParentForChild(resource.data.childId) || (request.auth != null && request.auth.uid == resource.data.collaboratorId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']));
      allow delete: if false;
    }
    match /medications/{medicationId} {
      allow read: if isParentForChild(resource.data.childId) || isCollaboratorForChild(resource.data.childId);
      allow create: if isParentForChild(request.resource.data.childId) && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isParentForChild(resource.data.childId);
    }
    match /medicationLogs/{logId} {
      allow read: if isParentForChild(resource.data.childId) || isCollaboratorForChild(resource.data.childId);
      allow create, update: if request.auth != null && (isParentForChild(request.resource.data.childId) || isCollaboratorForChild(request.resource.data.childId));
      allow delete: if isParentForChild(resource.data.childId);
    }
    match /invitations/{invitationId} {
      allow read: if request.auth != null && (request.auth.token.email == resource.data.toEmail || request.auth.token.email == resource.data.fromEmail);
      allow create: if request.auth != null && request.auth.token.email == request.resource.data.fromEmail;
      allow update: if request.auth != null && ((request.auth.token.email == resource.data.toEmail) || (request.auth.token.email == resource.data.fromEmail)) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'createdAt']);
    }
    match /notes/{noteId} {
      allow read, delete: if isParentForChild(resource.data.childId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.createdBy && isParentForChild(request.resource.data.childId);
      allow update: if isParentForChild(resource.data.childId);
    }
    match /schoolEvents/{eventId} {
      allow read, update, delete: if isParentForChild(resource.data.childId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.createdBy && isParentForChild(request.resource.data.childId);
    }
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId is string
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.type is string
        && request.resource.data.read == false;
      allow delete: if false;
    }
    match /documents/{documentId} {
      allow read, update, delete: if isParentForChild(resource.data.childId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.createdBy && isParentForChild(request.resource.data.childId);
    }
    match /userDocumentKeys/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }
    match /packingItems/{itemId} {
      allow read, update, delete: if isParentForChild(resource.data.childId);
      allow create: if isParentForChild(request.resource.data.childId);
    }
    match /specialPeriods/{periodId} {
      allow read: if isParentForChild(resource.data.childId) || collaboratorHasFullCalendar(resource.data.childId);
      allow update, delete: if isParentForChild(resource.data.childId);
      allow create: if isParentForChild(request.resource.data.childId);
    }
  }
}
